@model HomeIndexViewModel

@{
    ViewData["Title"] = "Ana Sayfa";
    var role = Model.Role;
    var name = Model.Name;
}

@if (role == null)
{
    <div class="text-center py-5">
        <h1 class="fw-bold">ClinicMvc</h1>
        <p class="lead text-muted">Randevunu kolayca al, sağlığını takip et.</p>
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary rounded-pill px-4 me-2">Giriş Yap</a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary rounded-pill px-4">Kaydol</a>
        </div>
    </div>
    <div class="row g-4 mt-2">
        <div class="col-md-4"><div class="card border-0 shadow-sm rounded-4 h-100 text-center p-3"><div class="fs-1">🙋</div><h5>Hasta</h5><p class="text-muted small">Doktor seç, randevu al, geçmişini gör.</p></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm rounded-4 h-100 text-center p-3"><div class="fs-1">🩺</div><h5>Doktor</h5><p class="text-muted small">Randevu yönet, reçete yaz.</p></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm rounded-4 h-100 text-center p-3"><div class="fs-1">🛡️</div><h5>Yönetici</h5><p class="text-muted small">Doktor ve branş yönetimi.</p></div></div>
    </div>
}
else
{
    <div class="mb-4">
        <h3 class="fw-bold mb-0">Hoş geldin, @name 👋</h3>
        <p class="text-muted">@role paneli</p>
    </div>

    @if (role == "Admin")
    {
        <div class="row g-4">
            <div class="col-md-4"><a asp-controller="Department" asp-action="Index" class="text-decoration-none text-dark">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4"><div class="fs-1">🏷️</div><h5 class="mt-2">Branşlar</h5><p class="text-muted small mb-0">Branş ekle / düzenle / sil.</p></div></a></div>
            <div class="col-md-4"><a asp-controller="Doctor" asp-action="Index" class="text-decoration-none text-dark">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4"><div class="fs-1">🩺</div><h5 class="mt-2">Doktorlar</h5><p class="text-muted small mb-0">Doktor ekle, no/şifre/branş belirle.</p></div></a></div>
        </div>
    }
    else if (role == "Doctor" && Model.Doctor != null)
    {
        var d = Model.Doctor;

        <div class="row g-3 mb-3">
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Bugünkü Randevu</div>
                <div class="display-6 fw-bold">@d.TodayCount</div></div></div>
            <div class="col-md-3"><a asp-controller="DoctorPanel" asp-action="Pending" class="text-decoration-none text-dark">
                <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                    <div class="text-muted small">Onay Bekleyen</div>
                    <div class="display-6 fw-bold text-warning">@d.PendingCount</div></div></a></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Bu Hafta Hasta</div>
                <div class="display-6 fw-bold">@d.WeekPatientCount</div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Tamamlanan</div>
                <div class="display-6 fw-bold text-success">@d.CompletedCount</div></div></div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-4"><div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Ortalama Puan</div>
                <div class="display-6 fw-bold">@(d.TotalReviews > 0 ? d.AverageRating.ToString("0.0") : "—") <span class="fs-5">⭐</span></div></div></div>
            <div class="col-md-4"><div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Toplam Yorum</div>
                <div class="display-6 fw-bold">@d.TotalReviews</div></div></div>
            <div class="col-md-4"><div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Bu Ay Hasta</div>
                <div class="display-6 fw-bold">@d.ThisMonthPatientCount</div></div></div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-3 mb-3">
            <div class="d-flex justify-content-between mb-1">
                <span class="text-muted small">Bugünkü Doluluk</span>
                <span class="small">@d.TodayUsed / @d.MaxAppointments (%@d.OccupancyPercent)</span>
            </div>
            <div class="progress" style="height: 10px;">
                <div class="progress-bar bg-primary" role="progressbar" style="width: @(d.OccupancyPercent)%"></div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4"><div class="card-body">
            <h6 class="mb-3">Son Yorumlar</h6>
            @if (!d.RecentReviews.Any()) { <p class="text-muted small mb-0">Henüz yorum yok.</p> }
            @foreach (var r in d.RecentReviews)
            {
                <div class="mb-2 pb-2 border-bottom">
                    <strong>@r.PatientName</strong>
                    <span class="ms-2">⭐ @r.Score/5</span>
                    <span class="text-muted small ms-2">@r.CreatedAt.ToString("dd.MM.yyyy")</span>
                    @if (!string.IsNullOrWhiteSpace(r.Comment)) { <div class="small">@r.Comment</div> }
                </div>
            }
        </div></div>

        <div class="row g-4">
            <div class="col-md-4"><a asp-controller="DoctorPanel" asp-action="Index" class="text-decoration-none text-dark">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4"><div class="fs-1">📅</div><h5 class="mt-2">Randevularım</h5><p class="text-muted small mb-0">Tüm randevular, arama, sayfalama.</p></div></a></div>
            <div class="col-md-4"><a asp-controller="DoctorPanel" asp-action="Profile" class="text-decoration-none text-dark">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4"><div class="fs-1">👤</div><h5 class="mt-2">Profil</h5><p class="text-muted small mb-0">Hakkında ve şifre.</p></div></a></div>
            <div class="col-md-4"><a asp-controller="DoctorPanel" asp-action="Settings" class="text-decoration-none text-dark">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4"><div class="fs-1">⚙️</div><h5 class="mt-2">Ayarlar</h5><p class="text-muted small mb-0">Oda, max randevu, mesai.</p></div></a></div>
        </div>
    }
    else if (role == "Patient" && Model.Patient != null)
    {
        var p = Model.Patient;

        <div class="row g-3 mb-3">
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Yaklaşan</div>
                <div class="display-6 fw-bold">@p.UpcomingCount</div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Onay Bekleyen</div>
                <div class="display-6 fw-bold text-warning">@p.PendingCount</div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Tamamlanan</div>
                <div class="display-6 fw-bold text-success">@p.CompletedCount</div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Toplam Randevu</div>
                <div class="display-6 fw-bold">@p.TotalCount</div></div></div>
        </div>

        @if (p.MostVisitedDoctor != null)
        {
            <div class="card border-0 shadow-sm rounded-4 p-3 mb-4">
                <span class="text-muted small">En Sık Gittiğin Doktor</span>
                <div class="fs-4 fw-semibold">@p.MostVisitedDoctor <span class="text-muted fs-6">· @p.MostVisitedCount muayene</span></div>
            </div>
        }

        <div class="row g-4">
            <div class="col-md-6"><a asp-controller="PatientPanel" asp-action="Doctors" class="text-decoration-none text-dark">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4"><div class="fs-1">🔍</div><h5 class="mt-2">Doktor Bul</h5><p class="text-muted small mb-0">Branşa göre ara, randevu al.</p></div></a></div>
            <div class="col-md-6"><a asp-controller="PatientPanel" asp-action="MyAppointments" class="text-decoration-none text-dark">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4"><div class="fs-1">📅</div><h5 class="mt-2">Randevularım</h5><p class="text-muted small mb-0">Geçmiş ve yaklaşan randevular.</p></div></a></div>
        </div>
    }
}