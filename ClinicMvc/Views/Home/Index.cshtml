@{
    ViewData["Title"] = "Ana Sayfa";
    var role = Context.Session.GetString("Role");
}

<div class="text-center py-5">
    <h1 class="fw-bold">ClinicMvc</h1>
    <p class="lead text-muted">Randevunu kolayca al, sağlığını takip et.</p>
    @if (role == null)
    {
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary rounded-pill px-4 me-2">Giriş Yap</a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary rounded-pill px-4">Kaydol</a>
        </div>
    }
    else
    {
        <p class="mt-3">Hoş geldin, <strong>@Context.Session.GetString("UserName")</strong> 👋</p>
    }
</div>

<div class="row g-4 mt-2">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 text-center p-3">
            <div class="fs-1">🙋</div><h5>Hasta</h5>
            <p class="text-muted small">Doktor seç, randevu al, geçmişini ve reçetelerini gör.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 text-center p-3">
            <div class="fs-1">🩺</div><h5>Doktor</h5>
            <p class="text-muted small">Randevularını yönet, reçete yaz, oda ve limitini ayarla.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 text-center p-3">
            <div class="fs-1">🛡️</div><h5>Yönetici</h5>
            <p class="text-muted small">Doktor ve branşları yönet.</p>
        </div>
    </div>
</div>