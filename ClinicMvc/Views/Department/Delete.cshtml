@model ClinicMvc.Models.Department
@{ ViewData["Title"] = "Branş Sil"; }

<div class="row justify-content-center"><div class="col-md-5">
    <div class="card border-0 shadow-sm rounded-4"><div class="card-body text-center">
        <h4 class="mb-3">Branşı sil?</h4>
        <p><strong>@Model.Name</strong> silinecek. Emin misin?</p>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger rounded-pill px-4">Evet, sil</button>
            <a asp-action="Index" class="btn btn-link">Vazgeç</a>
        </form>
    </div></div>
</div></div>