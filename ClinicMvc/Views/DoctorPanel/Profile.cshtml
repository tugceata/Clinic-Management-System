@model ClinicMvc.Models.Doctor
@{ ViewData["Title"] = "Profil"; }

<div class="row justify-content-center"><div class="col-md-7">
<div class="card border-0 shadow-sm rounded-4 mb-4"><div class="card-body">
    <h4 class="mb-3">Profilim</h4>
    @if (TempData["Msg"] != null) { <div class="alert alert-success py-2">@TempData["Msg"]</div> }

    <div class="mb-2"><span class="text-muted small">Ad Soyad</span><div class="fw-semibold">@Model.FullName</div></div>
    <div class="mb-2"><span class="text-muted small">Doktor No</span><div>@Model.DoctorNumber</div></div>
    <div class="mb-2"><span class="text-muted small">Uzmanlık</span>
        <div>@Model.Department?.Name <span class="badge bg-light text-muted">admin belirler</span></div></div>
    <div class="mb-0"><span class="text-muted small">Şifre</span><div>••••••••</div></div>
</div></div>

<div class="card border-0 shadow-sm rounded-4 mb-4"><div class="card-body">
    <h6>Hakkında</h6>
    <form asp-action="UpdateBio" method="post">
        <textarea name="bio" class="form-control rounded-3 mb-2" rows="3">@Model.Bio</textarea>
        <button class="btn btn-outline-primary rounded-pill px-4">Kaydet</button>
    </form>
</div></div>

<div class="card border-0 shadow-sm rounded-4"><div class="card-body">
    <h6>Şifre Değiştir</h6>
    @if (TempData["PwError"] != null) { <div class="alert alert-danger py-2">@TempData["PwError"]</div> }
    <form asp-action="ChangePassword" method="post">
        <input name="oldPassword" type="password" class="form-control rounded-3 mb-2" placeholder="Eski şifre" />
        <input name="newPassword" type="password" class="form-control rounded-3 mb-2" placeholder="Yeni şifre" />
        <input name="confirmPassword" type="password" class="form-control rounded-3 mb-3" placeholder="Yeni şifre (tekrar)" />
        <button class="btn btn-primary rounded-pill px-4">Şifreyi Değiştir</button>
    </form>
</div></div>
</div></div>