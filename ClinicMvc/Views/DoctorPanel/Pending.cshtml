@using ClinicMvc.Models
@model List<ClinicMvc.Models.Appointment>
@{ ViewData["Title"] = "Onay Bekleyenler"; }

<h3 class="mb-3">Onay Bekleyen Randevular</h3>

@if (!Model.Any()) { <p class="text-muted">Bekleyen randevu yok.</p> }
else
{
    <table class="table table-hover align-middle">
        <thead><tr><th>Hasta</th><th>Yaş</th><th>Tarih</th><th class="text-end">İşlem</th></tr></thead>
        <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.Patient?.FullName</td>
                <td>@a.Patient?.Age</td>
                <td>@a.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td class="text-end">
                    <form asp-action="Approve" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@a.Id" />
                        <button class="btn btn-sm btn-success rounded-pill px-3">Onayla</button>
                    </form>
                    <form asp-action="CancelAppt" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@a.Id" />
                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3">Reddet</button>
                    </form>
                    <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3">Detay</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}