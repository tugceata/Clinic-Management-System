@using ClinicMvc.Models
@model ClinicMvc.Models.Appointment
@{ ViewData["Title"] = "Randevu Detayı"; }

<h3 class="mb-3">Randevu Detayı</h3>
@if (TempData["Msg"] != null) { <div class="alert alert-success py-2">@TempData["Msg"]</div> }

<div class="row g-4">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm rounded-4 mb-4"><div class="card-body">
            <h6 class="text-muted">Hasta</h6>
            <p class="mb-1 fw-semibold">@Model.Patient?.FullName <span class="text-muted small">· @Model.Patient?.Age yaşında</span></p>
            <p class="mb-1 small text-muted">@Model.Patient?.Phone · @Model.Patient?.Email</p>
            <hr />
            <p class="mb-1"><span class="text-muted">Tarih:</span> @Model.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</p>
            <p class="mb-0"><span class="text-muted">Mevcut durum:</span> <strong>@Model.Status.ToTr()</strong></p>
        </div></div>

        <div class="card border-0 shadow-sm rounded-4"><div class="card-body">
            <h6 class="mb-3">Doktor Bilgileri (sen doldur)</h6>
            <form asp-action="UpdateDetails" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="mb-3">
                    <label class="form-label">Durum</label>
                    <select name="status" class="form-select rounded-3">
                        @foreach (var s in Enum.GetValues<AppointmentStatus>())
                        {
                            <option value="@s" selected="@(Model.Status == s)">@s.ToTr()</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Teşhis</label>
                    <textarea name="diagnosis" class="form-control rounded-3" rows="2" placeholder="Henüz teşhis girilmedi...">@Model.Diagnosis</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Not</label>
                    <textarea name="notes" class="form-control rounded-3" rows="2" placeholder="Not ekle...">@Model.Notes</textarea>
                </div>
                <button class="btn btn-primary rounded-pill px-4">Kaydet</button>
                <a asp-action="Index" class="btn btn-link">Geri</a>
            </form>
        </div></div>
    </div>

    <div class="col-md-5">
        <div class="card border-0 shadow-sm rounded-4"><div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="mb-0">Reçeteler</h6>
                <a asp-action="Prescribe" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary rounded-pill">+ Reçete</a>
            </div>
            @if (Model.Prescriptions.Any())
            {
                <ul class="list-group list-group-flush">
                @foreach (var p in Model.Prescriptions)
                {
                    <li class="list-group-item px-0">
                        <strong>@p.Medication</strong> — @p.Dosage
                        <div class="text-muted small">@p.Instructions</div>
                    </li>
                }
                </ul>
            }
            else { <p class="text-muted small mb-0">Henüz reçete yok. "+ Reçete" ile ekle.</p> }
        </div></div>
    </div>
</div>