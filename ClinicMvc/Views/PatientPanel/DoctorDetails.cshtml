@model DoctorDetailViewModel
@{ ViewData["Title"] = "Doktor Detayı"; }

<div class="row g-4">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm rounded-4"><div class="card-body">
            <h3 class="mb-1">@Model.Doctor.FullName</h3>
            <span class="badge bg-light text-muted">@Model.Doctor.Department?.Name</span>
            <p class="mt-3 mb-1">⭐ @(Model.ReviewCount > 0 ? Model.AverageRating.ToString("0.0") : "—") <span class="text-muted">(@Model.ReviewCount yorum)</span></p>
            <p class="text-muted small">Oda @Model.Doctor.RoomNumber · Mesai @Model.Doctor.WorkStartHour:00 - @Model.Doctor.WorkEndHour:00</p>
            @if (!string.IsNullOrWhiteSpace(Model.Doctor.Bio)) { <hr /><p class="mb-0">@Model.Doctor.Bio</p> }
            <div class="mt-3">
                @if (Model.HasCompleted)
                {
                    if (Model.HasReview)
                    {
                        <a asp-action="Review" asp-route-doctorId="@Model.Doctor.Id" class="btn btn-outline-secondary rounded-pill px-4">Yorumu Düzenle</a>
                    }
                    else
                    {
                        <a asp-action="Review" asp-route-doctorId="@Model.Doctor.Id" class="btn btn-outline-primary rounded-pill px-4">Puan Ver</a>
                    }
                }
                <a asp-action="Book" asp-route-doctorId="@Model.Doctor.Id" class="btn btn-primary rounded-pill px-4">Randevu Al</a>
                <a asp-action="Doctors" class="btn btn-link">Geri</a>
            </div>
        </div></div>
    </div>
    <div class="col-md-5">
        <div class="card border-0 shadow-sm rounded-4"><div class="card-body">
            <h6 class="mb-3">Yorumlar</h6>
            @if (!Model.Reviews.Any()) { <p class="text-muted small mb-0">Henüz yorum yok.</p> }
            else
            {
                @foreach (var r in Model.Reviews)
                {
                    <div class="mb-3">
                        <strong>@r.Patient?.FullName</strong>
                        <span class="ms-2">⭐ @r.Score/5</span>
                        <div class="text-muted small">@r.CreatedAt.ToString("dd.MM.yyyy")</div>
                        @if (!string.IsNullOrWhiteSpace(r.Comment)) { <div class="small mt-1">@r.Comment</div> }
                    </div>
                }
            }
        </div></div>
    </div>
</div>