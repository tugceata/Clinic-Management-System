@using ClinicMvc.Models
@model List<ClinicMvc.Models.Appointment>
@{
    ViewData["Title"] = "Randevularım";
    var reviewedDoctorIds = ViewBag.ReviewedDoctorIds as HashSet<int> ?? new();
    Func<AppointmentStatus, string> badge = s => s switch
    {
        AppointmentStatus.Approved  => "info",
        AppointmentStatus.Completed => "success",
        AppointmentStatus.Cancelled => "danger",
        _ => "warning"
    };
}

<h3 class="mb-3">Randevularım</h3>
@if (TempData["Msg"] != null) { <div class="alert alert-success py-2">@TempData["Msg"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger py-2">@TempData["Error"]</div> }

<table class="table table-hover align-middle">
    <thead><tr><th>Doktor</th><th>Branş</th><th>Tarih</th><th>Durum</th><th>Teşhis</th><th>Reçete</th><th></th></tr></thead>
    <tbody>
    @if (!Model.Any()) { <tr><td colspan="7" class="text-center text-muted">Henüz randevun yok.</td></tr> }
    @foreach (var a in Model)
    {
        <tr>
            <td>@a.Doctor?.FullName</td>
            <td>@a.Doctor?.Department?.Name</td>
            <td>@a.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
            <td><span class="badge bg-@badge(a.Status)">@a.Status.ToTr()</span></td>
            <td class="small text-muted">@(string.IsNullOrWhiteSpace(a.Diagnosis) ? "—" : a.Diagnosis)</td>
            <td>
                @if (a.Prescriptions.Any())
                {
                    foreach (var p in a.Prescriptions) { <div class="small"><strong>@p.Medication</strong> @p.Dosage</div> }
                }
                else { <span class="text-muted small">—</span> }
            </td>
            <td class="text-end">
                @if (a.Status == AppointmentStatus.Completed && a.Doctor != null)
                {
                    if (reviewedDoctorIds.Contains(a.Doctor.Id))
                    {
                        <a asp-action="Review" asp-route-doctorId="@a.Doctor.Id" class="btn btn-sm btn-outline-secondary rounded-pill">Yorumu Düzenle</a>
                    }
                    else
                    {
                        <a asp-action="Review" asp-route-doctorId="@a.Doctor.Id" class="btn btn-sm btn-outline-primary rounded-pill">Puan Ver</a>
                    }
                }
            </td>
        </tr>
    }
    </tbody>
</table>